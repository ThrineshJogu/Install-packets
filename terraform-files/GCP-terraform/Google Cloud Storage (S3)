

provider "google" {
  project = "project-9c5ad7f6-f26e-49ac-819"
  region  = "europe-north1"
}


resource "google_storage_bucket" "mybucket" {
  name     = var.bucket_name
  location = "EUROPE-NORTH1"
  uniform_bucket_level_access = true
  
  versioning {
    enabled = true
  }
   force_destroy = true # ✅ allows deleting non-empty bucket
}



variable "bucket_name" {
  type    = string
  default = "thrinesh-bucket-12345"
}


#storing statefile in Google Cloud Storage

backend.tf

terraform {
  backend "gcs" {
    bucket  = "thrinesh-bucket-12345"
    prefix  = "prod/terraform"
  }
}
