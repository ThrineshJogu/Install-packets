provider.tf

provider "google" {
  project = var.project_id
  region  = var.region
  zone    = var.zone
}

resource.tf

resource "google_compute_instance" "myinstance" {

  count        = var.count
  name         = var.name[count.index]
  machine_type = "e2-micro"
  zone         = var.zone

  tags = ["dev", "flm"]

  labels = {
    env    = "dev"
    client = "flm"
  }

  boot_disk {
    initialize_params {
      image = "debian-cloud/debian-11"
    }
  }

  network_interface {
    network = "default"

    access_config {
      # Ephemeral public IP
    }
  }

  metadata = {
    ssh-keys = "username:${file(var.public_key_path)}"
  }
}


variables.tf


variable "project_id" {
  type = string
}

variable "region" {
  default = "europe-north1"
}

variable "zone" {
  default = "europe-north1-a"
}

variable "name" {
  type    = list(string)
  default = ["server-1", "server-2", "server-3"]
}

variable "count" {
  type    = number
  default = 3
}

variable "public_key_path" {
  description = "Path to SSH public key"
  default     = "~/.ssh/id_rsa.pub"
}
