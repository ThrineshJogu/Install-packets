provider.tf

provider "google" {
  project = "your-project-id"
  region  = "us-central1"
  zone    = "us-central1-b"
}


resource.tf
  
resource "google_compute_instance" "myserver" {

  count        = 2
  name         = "flm-terraform-server-${count.index}"
  machine_type = "e2-micro"
  zone         = "us-central1-b"

  tags = ["dev", "zomato"]

  boot_disk {
    initialize_params {
      image = "debian-cloud/debian-11"
      size  = 20
    }
  }

  network_interface {
    network = "default"

    access_config {
      # This block gives external IP
    }
  }

  metadata = {
    Name        = "flm-terraform-server"
    Environment = "dev"
    Client      = "zomato"
  }
}
