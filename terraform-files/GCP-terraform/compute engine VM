provider.tf

provider "google" {
  project = "project-9c5ad7f6-f26e-49ac-819"
  region  = "us-central1"
  zone    = "us-central1-b"
}


resource.tf
  
resource "google_compute_instance" "myserver" {

  count        = 2
  name         = "flm-terraform-server-${count.index}"
  machine_type = "e2-micro"
  zone         = "us-central1-b"

  tags = ["dev", "zomato"]

  boot_disk {
    initialize_params {
      image = "debian-cloud/debian-11"
      size  = 20
    }
  }

  network_interface {
    network = "default"

    access_config {
      # This block gives external IP
    }
  }

  metadata = {
    Name        = "flm-terraform-server"
    Environment = "dev"
    Client      = "zomato"
  }
}




public subnet:

network_interface {

    # Attach VM to custom VPC
    network    = google_compute_network.myvpc.id

    # Attach VM to public subnet
    subnetwork = google_compute_subnetwork.public_subnet.id

    # External Public IP
    access_config {
    }
  }

