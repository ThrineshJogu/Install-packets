Overall Architecture

VPC (10.0.0.0/16)
│
├── Public Subnet (10.0.0.0/25)
│     └── VMs with External IP → Internet access directly
│
├── Private Subnet (10.0.0.128/25)
│     └── VMs WITHOUT External IP
│            ├── Access Google APIs (via Private Google Access)
│            └── Access Internet (via Cloud NAT)
│
└── Cloud NAT + Router
      └── Enables outbound internet for private subnet




provider "google" {
  project = "your-project-id"
  region  = "europe-north1"
}

# 1. VPC Network

resource "google_compute_network" "myvpc" {
  name                    = "terraform-vpc"
  auto_create_subnetworks = false
}

# 2. Public Subnet

resource "google_compute_subnetwork" "public_subnet" {
  name          = "public-subnet"
  ip_cidr_range = "10.0.0.0/25"
  region        = "europe-north1"
  network       = google_compute_network.myvpc.id
}

# 3. Private Subnet

resource "google_compute_subnetwork" "private_subnet" {
  name          = "private-subnet"
  ip_cidr_range = "10.0.0.128/25"
  region        = "europe-north1"
  network       = google_compute_network.myvpc.id

  # Enables Private Google Access (important)
  private_ip_google_access = true
}

# 4. Cloud Router (Required for NAT)

resource "google_compute_router" "router" {
  name    = "nat-router"
  network = google_compute_network.myvpc.id
  region  = "europe-north1"

  bgp {
    asn = 64514
  }
}

# 5. Cloud NAT (Equivalent of AWS NAT Gateway)

resource "google_compute_router_nat" "nat" {
  name                               = "cloud-nat"
  router                             = google_compute_router.router.name
  region                             = "europe-north1"
  nat_ip_allocate_option             = "AUTO_ONLY"
  source_subnetwork_ip_ranges_to_nat = "ALL_SUBNETWORKS_ALL_IP_RANGES"

  depends_on = [google_compute_router.router]
}
